{
	"name": "oid4vp-cli-utils",
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"bin": {
		"wallet-cli": "./dist/wallet-cli/index.js",
		"issuer-cli": "./dist/issuer-cli/index.js"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"build": "bun build packages/wallet-cli/src/index.ts --target=bun --outdir=dist/wallet-cli --entry-naming=[name].js && bun build packages/issuer-cli/src/index.ts --target=bun --outdir=dist/issuer-cli --entry-naming=[name].js",
		"postinstall": "bun run build",
		"check-types": "tsc --noEmit --project tsconfig.json",
		"demo:e2e": "bun scripts/demo-e2e.ts",
		"test": "bun test",
		"lint": "biome check --write ."
	},
	"packageManager": "bun@1.3.10",
	"dependencies": {
		"@sd-jwt/core": "^0.19.0",
		"@sd-jwt/decode": "^0.19.0",
		"@sd-jwt/hash": "^0.19.0",
		"@sd-jwt/present": "^0.19.0",
		"@sd-jwt/sd-jwt-vc": "^0.19.0",
		"commander": "^14.0.3",
		"dcql": "^3.0.0",
		"jose": "^6.2.2",
		"zod": "^4.3.6"
	}
}
