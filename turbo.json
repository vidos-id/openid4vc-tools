{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^check-types"],
			"inputs": [
				"src/**/*.ts",
				"src/**/*.tsx",
				"src/**/*.js",
				"src/**/*.jsx",
				"src/**/*.json",
				"package.json",
				"tsconfig.json",
				"tsconfig.*.json",
				"vite.config.ts",
				"index.html",
				"drizzle.config.ts"
			],
			"outputs": ["dist/**", "build/**", "drizzle/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"inputs": [
				"src/**/*.ts",
				"src/**/*.tsx",
				"src/**/*.d.ts",
				"package.json",
				"tsconfig.json",
				"tsconfig.*.json",
				"vite.config.ts",
				"drizzle.config.ts"
			],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^check-types"],
			"inputs": [
				"src/**/*.ts",
				"src/**/*.tsx",
				"**/*.test.ts",
				"**/*.test.tsx",
				"package.json",
				"tsconfig.json",
				"tsconfig.*.json"
			],
			"outputs": []
		},
		"lint": {
			"inputs": [
				"src/**/*.ts",
				"src/**/*.tsx",
				"src/**/*.js",
				"src/**/*.jsx",
				"package.json",
				"tsconfig.json",
				"tsconfig.*.json"
			],
			"outputs": []
		}
	},
	"globalDependencies": [
		"turbo.json",
		"package.json",
		"bun.lock",
		"tsconfig.json",
		"**/.env",
		"**/.env.*",
		"**/.env.local"
	]
}
