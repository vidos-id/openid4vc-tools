{
	"name": "@vidos-id/openid4vc-issuer",
	"description": "Issuer library for holder-bound dc+sd-jwt credentials.",
	"version": "0.10.0-rc1",
	"repository": {
		"type": "git",
		"url": "https://github.com/vidos-id/openid4vc-tools.git"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit --project ../../tsconfig.json",
		"publish": "bun publish",
		"test": "bun --conditions=development test --pass-with-no-tests"
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"development": {
				"types": "./src/index.ts",
				"default": "./src/index.ts"
			},
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"@sd-jwt/core": "^0.19.0",
		"@sd-jwt/hash": "^0.19.0",
		"@sd-jwt/sd-jwt-vc": "^0.19.0",
		"jose": "^6.2.2",
		"zod": "^4.3.6"
	}
}
