{
	"name": "@vidos-id/openid4vc-issuer-cli",
	"description": "CLI client for issuer-web-server.",
	"version": "0.9.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/vidos-id/openid4vc-tools.git"
	},
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"openid4vc-issuer": "./src/index.ts"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"scripts": {
		"build": "bun build src/index.ts --target=bun --outdir=../../dist/openid4vc-issuer --entry-naming=[name].js --define __CLI_VERSION__='\"'$npm_package_version'\"'",
		"check-types": "tsc --noEmit --project ../../tsconfig.json",
		"test": "bun test --pass-with-no-tests"
	},
	"dependencies": {
		"@vidos-id/openid4vc-cli-common": "workspace:*",
		"@vidos-id/openid4vc-issuer-web-shared": "workspace:*",
		"commander": "^14.0.3",
		"inquirer": "^12.9.6",
		"zod": "^4.3.6"
	}
}
