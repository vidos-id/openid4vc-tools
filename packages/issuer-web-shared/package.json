{
	"name": "@vidos-id/openid4vc-issuer-web-shared",
	"version": "0.10.0-rc1",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vidos-id/openid4vc-tools.git",
		"directory": "packages/issuer-web-shared"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"development": {
				"types": "./src/index.ts",
				"default": "./src/index.ts"
			},
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit --project tsconfig.json",
		"package-publish": "npm publish",
		"test": "bun --conditions=development test --pass-with-no-tests"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"zod": "^4.3.6"
	}
}
